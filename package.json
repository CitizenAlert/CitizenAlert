{
  "name": "citizen-alert",
  "version": "1.0.0",
  "private": true,
  "description": "Hazard reporting mobile application - monorepo",
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:mobile": "pnpm --filter mobile start",
    "build:api": "pnpm --filter api build",
    "build:mobile": "pnpm --filter mobile build",
    "db:migrate": "pnpm --filter api typeorm migration:run",
    "db:migrate:revert": "pnpm --filter api typeorm migration:revert",
    "db:shell": "docker exec -it citizen-alert-postgres psql -U postgres -d citizen_alert",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
