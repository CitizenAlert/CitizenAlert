# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=citizen_alert

# ============================================
# API CONFIGURATION
# ============================================
API_PORT=3001

# ============================================
# GOOGLE MAPS
# ============================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ============================================
# IMAGE MODERATION (OpenAI)
# ============================================
# Modération des images (contenu interdit) + pertinence (type/description)
OPENAI_API_KEY=sk-...
# Modération du contenu
IMAGE_MODERATION_ENABLED=true
# Pertinence image / type d'incident (payant, modèle vision)
IMAGE_RELEVANCE_CHECK_ENABLED=true
OPENAI_VISION_MODEL=gpt-4o-mini
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d
ALLOWED_ORIGINS=http://localhost:3004,http://localhost:8081,http://10.141.113.170:3004

# Database URL (for TypeORM)
# Note: Using port 5434 externally, but 5432 internally in Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/citizen_alert

# ============================================
# MOBILE APP CONFIGURATION
# ============================================
# FOR EXPO GO ON YOUR PHONE:
#
# This IP (10.141.113.170) is your computer's IP on the network.
# Expo Go on your phone will use this IP to connect to the Docker API.
#
# If you're on a different computer or network, replace 10.141.113.170
# with your computer's IP address. Find it with:
#   - Linux/Mac: hostname -I | awk '{print $1}'
#   - Windows: ipconfig (look for IPv4 Address)
#
# Then restart: make dev-mobile
#
# For local / Expo Go:
EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_IP:3001
#
# For EAS builds (internal test / production), the URL is set in apps/mobile/eas.json
# (e.g. EXPO_PUBLIC_API_URL=http://54.36.100.202/citizens_alert/api)

# ============================================
# S3 / MinIO (local storage for incident images)
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=citizen-alert-images
S3_REGION=us-east-1
S3_PORT=9000

# ============================================
# SUPER ADMIN CODE
# ============================================
# Secret code required to create super admin or mairie accounts
# Change this to a secure random string in production
SUPER_ADMIN_CODE=your-secret-code-here

# ============================================
# HOW TO CREATE SUPER ADMIN OR MAIRIE ACCOUNTS
# ============================================
# Use this curl command to create a super admin or mairie account:
#
# For SUPER ADMIN:
# curl -X POST http://localhost:3001/api/auth/register \
#   -H "Content-Type: application/json" \
#   -d '{
#     "email": "admin@example.com",
#     "password": "SecurePassword123!",
#     "firstName": "Admin",
#     "lastName": "User",
#     "role": "admin",
#     "adminCode": "your-secret-code-here"
#   }'
#
# For MAIRIE (Municipality):
# curl -X POST http://localhost:3001/api/auth/register \
#   -H "Content-Type: application/json" \
#   -d '{
#     "email": "mairie@ville.fr",
#     "password": "SecurePassword123!",
#     "firstName": "Mairie",
#     "lastName": "Ville",
#     "role": "municipality",
#     "adminCode": "your-secret-code-here"
#   }'
#
# Note: Replace "your-secret-code-here" with your SUPER_ADMIN_CODE from above
