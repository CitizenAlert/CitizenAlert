# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=citizen_alert

# ============================================
# API CONFIGURATION
# ============================================
API_PORT=3002
NODE_ENV=development
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:8081,http://YOUR_COMPUTER_IP:3002
# Get your IP: ip addr show | grep "inet " | grep -v "127.0.0.1"

# Database URL (for TypeORM)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/citizen_alert

# ============================================
# MOBILE APP CONFIGURATION
# ============================================
# FOR EXPO GO ON YOUR PHONE:
#
# Replace YOUR_COMPUTER_IP with your computer's actual IP address
# This allows your phone to connect to Docker running on your computer.
#
# HOW TO FIND YOUR IP:
#   Linux/Mac:   ifconfig | grep "inet " | grep -v 127.0.0.1
#   Windows:     ipconfig (look for IPv4 Address)
#
# EXAMPLE: http://192.168.1.100:3002
#
EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_IP:3002
